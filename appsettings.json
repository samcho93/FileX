{
  "FileX": {
    "Port": 5000,
    "DiscoveryPort": 5001,
    "ChunkSizeKB": 512,
    "MaxConcurrentTransfers": 3,
    "DiscoveryIntervalSeconds": 10,
    "PeerTimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
